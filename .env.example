# Environment Configuration for Local Development
# Copy this file to .env and customize as needed

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
POSTGRES_DB=postgres
POSTGRES_USER=postgres
# Note: In production (Docker), POSTGRES_PASSWORD is provided via file-based secrets.
# See docs/deployment/secrets.md for more details.
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ===========================================
# REDIS/VALKEY
# ===========================================
REDIS_URL=redis://localhost:6379
VALKEY_URL=redis://localhost:6379

# ===========================================
# ADMIN SERVICE (Nuxt - Port 3001)
# ===========================================
ADMIN_PORT=3001
ADMIN_HOST=localhost

# Supabase (for local development, use npx supabase start)
SUPABASE_URL=http://127.0.0.1:54321

# Note: In production (Docker), the following secrets are provided via file-based secrets.
# See docs/deployment/secrets.md for more details.
# SUPABASE_KEY: Supabase anonymous key
SUPABASE_KEY=your-anon-key
# SUPABASE_SERVICE_KEY: Supabase service role key
SUPABASE_SERVICE_KEY=your-service-key
# SUPABASE_JWT_SECRET: JWT token signing secret (needed in some Supabase configs)
SUPABASE_JWT_SECRET=your-jwt-secret

# Security
# IP_HASH_SALT: IP anonymization salt (provided via secret in prod)
IP_HASH_SALT=change-this-in-production
RATE_LIMIT_SALT=change-this-in-production
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# Logging
LOG_LEVEL=debug
SERVICE_NAME=admin-service

# SSE Sync (must match engine) (provided via secret in prod)
SYNC_API_KEY=local-dev-sync-key

# Analytics
ANALYTICS_DB_TIMEOUT=30000
ANALYTICS_AGGREGATION_INTERVAL=3600000

# ===========================================
# REDIRECT ENGINE (Hono - Port 3002)
# ===========================================
ENGINE_PORT=3002
ENGINE_HOST=localhost

# Admin Service URL for SSE sync
ADMIN_SERVICE_URL=http://localhost:3001/api/sync/stream
ANALYTICS_SERVICE_URL=http://localhost:3001

# SSE Sync (must match admin) (provided via secret in prod)
SYNC_API_KEY=local-dev-sync-key

# Environment
NODE_ENV=development

# ===========================================
# LAN TESTING NOTES
# ===========================================
# For LAN testing, replace localhost with your host machine IP:
#   ADMIN_SERVICE_URL=http://192.168.x.x:3001/api/sync/stream
#   ANALYTICS_SERVICE_URL=http://192.168.x.x:3001
#
# Also update CORS_ALLOWED_ORIGINS to include your LAN IP:
#   CORS_ALLOWED_ORIGINS=http://192.168.x.x:3001,http://192.168.x.x:3002
#
# Make sure firewall allows traffic on ports 3001 and 3002

# ===========================================
# CLOUDFLARE KV (optional — only for CF Worker deployments)
# ===========================================
# Required only when Cloudflare Worker engines are deployed.
# The Admin Service will push redirect rule changes to CF KV via the REST API.
# If unset, KV publishing is silently skipped (SSE-only mode).
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_KV_NAMESPACE_ID=your-kv-namespace-id
# CF_API_TOKEN=your-cloudflare-api-token
